    {
      "action": "/tool_runner/index",
      "citations": true,
      "config_file": "/cvmfs/test.galaxyproject.org/shed_tools/toolshed.g2.bx.psu.edu/repos/guerler/hhsuite/3e4d88784254/hhsuite/hhsearch.xml",
      "creator": null,
